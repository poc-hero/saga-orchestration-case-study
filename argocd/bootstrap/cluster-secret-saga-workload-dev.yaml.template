# Secret Argo CD pour enregistrer le cluster workloads "saga-workload-dev".
# À appliquer sur le cluster où tourne Argo CD (namespace argocd).
#
# Avant d'appliquer :
#   export WORKLOAD_BEARER_TOKEN="<token du ServiceAccount argocd-manager sur le cluster 84.234.26.236>"
#   export WORKLOAD_CA_DATA="<CA base64 du cluster 84.234.26.236>"
#   envsubst < argocd/bootstrap/cluster-secret-saga-workload-dev.yaml.template | kubectl apply -f -
#
# Pour obtenir le token et la CA, voir les instructions en bas de ce fichier.
apiVersion: v1
kind: Secret
metadata:
  name: cluster-workoad-dev
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: cluster
stringData:
  name: cluster-workload
  server: https://84.234.26.236:6443
  config: |
    {
      "bearerToken": "${WORKLOAD_BEARER_TOKEN}",
      "tlsClientConfig": {
        "insecure": false,
        "caData": "${WORKLOAD_CA_DATA}"
      }
    }
# ---
# Comment obtenir les valeurs :
#
# 1. Sur le cluster 84.234.26.236, créer un ServiceAccount + ClusterRoleBinding pour Argo CD :
#
#    kubectl create namespace argocd-manager 2>/dev/null || true
#    kubectl create serviceaccount argocd-manager -n argocd-manager
#    kubectl create clusterrolebinding argocd-manager-binding \
#      --clusterrole=cluster-admin \
#      --serviceaccount=argocd-manager:argocd-manager
#
# 2. Créer un token longue durée (K8s 1.24+) :
#
#    kubectl apply -f - <<'EOF'
#    apiVersion: v1
#    kind: Secret
#    metadata:
#      name: argocd-manager-token
#      namespace: argocd-manager
#      annotations:
#        kubernetes.io/service-account.name: argocd-manager
#    type: kubernetes.io/service-account-token
#    EOF
#
# 3. Récupérer le token :
#
#    export WORKLOAD_BEARER_TOKEN=$(kubectl -n argocd-manager get secret argocd-manager-token -o jsonpath='{.data.token}' | base64 -d)
#
# 4. Récupérer la CA (base64, une seule ligne) :
#
#    export WORKLOAD_CA_DATA=$(kubectl -n argocd-manager get secret argocd-manager-token -o jsonpath='{.data.ca\.crt}')
#
# 5. Appliquer ce template sur le cluster Argo CD :
#
#    envsubst < argocd/bootstrap/cluster-secret-saga-workload-dev.yaml.template | kubectl apply -f -
#
# Si le port API n'est pas 6443, adapter le champ "server" ci-dessus.
# Si TLS pose problème temporairement, passer "insecure": true (non recommandé en prod).
